# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/ping

# Port for the CRM API
PORT=4000

# URL of the channel service
CHANNEL_SERVICE_URL=http://localhost:4100

# Public URL of THIS service, used by the channel service to post receipts back
CRM_PUBLIC_URL=http://localhost:4000

# --- AI provider (optional - app falls back to rule-based logic without a key) ---
# Set ONE of these. Anthropic is used if both are set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o-mini
